generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id              Int            @id @default(autoincrement())
  name            String
  email           String         @unique
  jobId           Int
  stage           CandidateStage @default(applied)
  resume          String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  source          String?        @default("Direct")
  phone           String?
  rating          Int?           @default(0)
  interviewDate   DateTime?      @db.Timestamp(6)
  interviewers    String[]       @default([])
  offerLetterSent Boolean?       @default(false)
  joiningDate     String?
  offeredSalary   String?
  JobPosting      JobPosting     @relation(fields: [jobId], references: [id])

  @@index([deletedAt])
  @@index([jobId])
  @@index([stage])
  @@index([source])
  @@index([rating])
}

model Client {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  industry    String        @default("General")
  manager     String        @default("Unassigned")
  status      ClientStatus  @default(pending)
  revenue     String        @default("$0")
  location    String        @default("Unknown")
  avatar      String
  tier        ClientTier    @default(Growth)
  healthScore Int           @default(75)
  healthGrade String        @default("B")     // A+, A, B, C, D, F
  nextAction  String        @default("Initial contact")
  segment     ClientSegment @default(new_business)
  companyId   String?
  jobTitle    String?
  source      String?
  assignedTo  String?
  phone       String        @default("")
  company     String        @default("")
  tags        String[]      @default([])
  contacts    Contact[]
  meetings    Meeting[]
  
  // Health tracking
  lastContactDate DateTime?
  engagementScore Int        @default(50)  // 0-100
  
  // Contract info for renewals
  contractStartDate DateTime?
  contractEndDate   DateTime?
  
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime

  @@index([company])
  @@index([deletedAt])
  @@index([status])
  @@index([tier])
  @@index([healthScore])
  @@index([healthGrade])
  @@index([assignedTo])
  @@index([lastContactDate])
  @@index([contractEndDate])
}

model Conversation {
  id          Int       @id @default(autoincrement())
  name        String
  avatar      String
  lastMessage String
  time        String
  unread      Int       @default(0)
  online      Boolean   @default(false)
  team        String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Message     Message[]

  @@index([deletedAt])
  @@index([updatedAt])
}

model Invoice {
  id        String       @id
  client    String
  amount    String
  date      String
  due       String
  status    ClientStatus @default(pending)
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime

  @@index([deletedAt])
  @@index([status])
}

model JobPosting {
  id          Int         @id @default(autoincrement())
  title       String
  department  String
  location    String
  type        String      @default("Full-time")
  status      JobStatus   @default(open)
  description String      @default("")
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  salary      String?     @default("Competitive")
  experience  String?     @default("2-5 years")
  skills      String[]    @default([])
  views       Int?        @default(0)
  deadline    String?
  priority    String?     @default("normal")
  Candidate   Candidate[]

  @@index([deletedAt])
  @@index([status])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  sender         String
  text           String
  time           String
  isMe           Boolean      @default(false)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([deletedAt])
}

model Note {
  id        Int       @id @default(autoincrement())
  title     String
  content   String    @default("")
  isPinned  Boolean   @default(false)
  color     String    @default("default")
  authorId  String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime

  @@index([authorId])
  @@index([deletedAt])
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  description String        @default("")
  progress    Int           @default(0)
  status      ProjectStatus @default(pending)
  team        String[]      @default([])
  dueDate     String        @default("")
  stage       ProjectStage  @default(Discovery)
  budget      String        @default("$0")
  tasksDone   Int           @default(0)
  tasksTotal  Int           @default(0)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  tasks       Task[]
  comments    Comment[]
  attachments Attachment[]

  @@index([deletedAt])
  @@index([stage])
  @@index([status])
}

model RefreshToken {
  id        String    @id
  userId    String
  tokenHash String    @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  assignee    String
  avatar      String
  priority    TaskPriority
  dueDate     String
  tags        String[]     @default([])
  valueStream String
  column      TaskColumn   @default(todo)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  projectId   Int?
  project     Project?     @relation(fields: [projectId], references: [id], onUpdate: NoAction)
  comments    Comment[]
  attachments Attachment[]

  @@index([column])
  @@index([deletedAt])
  @@index([priority])
  @@index([projectId])
  @@index([dueDate])
  @@index([assignee])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  authorId  String
  taskId    Int?
  projectId Int?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  project   Project?  @relation(fields: [projectId], references: [id], onUpdate: NoAction)

  @@index([authorId])
  @@index([taskId])
  @@index([projectId])
  @@index([deletedAt])
}

model Attachment {
  id          Int      @id @default(autoincrement())
  filename    String
  originalName String
  url         String
  size        Int
  mimetype    String
  authorId    String
  taskId      Int?
  projectId   Int?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  project     Project?  @relation(fields: [projectId], references: [id], onUpdate: NoAction)

  @@index([authorId])
  @@index([taskId])
  @@index([projectId])
  @@index([deletedAt])
}

model TeamMember {
  id                    Int            @id @default(autoincrement())
  name                  String
  email                 String         @unique
  role                  TeamMemberRole
  status                ClientStatus   @default(active)
  avatar                String
  department            String
  team                  String
  teamId                Int?
  teamRef               Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  designation           String
  manager               String
  workingHours          String
  officeLocation        String
  timeZone              String
  baseSalary            Int
  allowances            Int
  deductions            Int
  paymentMode           PaymentMode
  warningCount          Int            @default(0)
  suspendedAt           DateTime?
  terminationEligibleAt DateTime?
  handoverCompletedAt   DateTime?
  terminatedAt          DateTime?
  separationNote        String?
  attendance            String         @default("present")
  checkIn               String         @default("-")
  location              String         @default("-")
  workload              Int            @default(0)
  deletedAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime

  @@index([deletedAt])
  @@index([role])
  @@index([status])
  @@index([teamId])
}

model User {
  id             String         @id
  name           String
  email          String         @unique
  passwordHash   String
  emailVerified  Boolean        @default(false)
  role           UserRole
  employeeId     String         @unique
  department     String
  team           String
  designation    String
  manager        String
  workingHours   String
  officeLocation String
  timeZone       String
  baseSalary     Int
  allowances     Int
  deductions     Int
  paymentMode    PaymentMode
  payrollCycle   String
  payrollDueDate String
  joinedAt       String
  location       String
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  signatureUrl   String?
  RefreshToken   RefreshToken[]
  comments       Comment[]
  attachments    Attachment[]
}

model UserPreference {
  id        String   @id
  userId    String   @unique
  data      Json     @default("{}")
  updatedAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Lead {
  id         Int        @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String     @unique
  company    String
  jobTitle   String?
  phone      String?
  status     LeadStatus @default(new)
  source     LeadSource @default(website)
  score      Int        @default(50)
  assignedTo String?
  assignedAt DateTime?
  notes      String?
  tags       String[]   @default([])
  convertedAt DateTime?
  convertedToClientId Int?
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Extended fields for scoring
  companySize String?
  budget      String?
  timeline    String?

  // Activity tracking
  lastContactDate DateTime?

  // Relations
  meetings    Meeting[]

  @@index([deletedAt])
  @@index([status])
  @@index([source])
  @@index([score])
  @@index([assignedTo])
  @@index([updatedAt])
  @@index([createdAt])
  @@index([company])
}

model Contact {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String    @unique
  phone        String?
  jobTitle     String?
  department   String?
  clientId     Int?
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  meetings     Meeting[]
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([deletedAt])
  @@index([clientId])
  @@index([email])
}

model Deal {
  id            Int            @id @default(autoincrement())
  title         String
  value         Int
  currency      String         @default("USD")
  stage         DealStage      @default(prospecting)
  probability   Int            @default(50)
  assignedTo    String?
  expectedClose DateTime?
  actualClose   DateTime?
  description   String?
  tags          String[]       @default([])
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activities    DealActivity[]

  @@index([deletedAt])
  @@index([stage])
  @@index([assignedTo])
  @@index([updatedAt])
}

model DealActivity {
  id        Int      @id @default(autoincrement())
  dealId    Int
  type      String
  content   String
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model CandidateActivity {
  id          Int      @id @default(autoincrement())
  candidateId Int
  action      String
  detail      String
  performedBy String
  createdAt   DateTime @default(now())

  @@index([candidateId])
}

model Integration {
  id          String   @id // composite key via @@unique
  userId      String
  name        String
  status      String   @default("disconnected")
  config      Json     @default("{}")
  connectedAt DateTime?
  lastSynced  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@unique([id, userId])
  @@index([userId])
}

enum UserRole {
  admin
  manager
  employee
  client
}

enum PaymentMode {
  bank_transfer
  cash
  upi
}

enum ClientStatus {
  active
  pending
  completed
}

enum ClientTier {
  Enterprise
  Growth
  Strategic
}

enum ClientSegment {
  Expansion
  Renewal
  new_business
}

enum ProjectStatus {
  active
  pending
  completed
  in_progress
}

enum ProjectStage {
  Discovery
  Build
  Review
  Launch
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskColumn {
  todo
  in_progress
  done
}

enum TeamMemberRole {
  Admin
  Manager
  Employee
}

enum JobStatus {
  open
  draft
  closed
}

enum CandidateStage {
  applied
  screening
  interview
  offer
  hired
  rejected
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  negotiation
  closed_won
  closed_lost
}

enum LeadSource {
  website
  referral
  social
  email
  other
}

enum DealStage {
  prospecting
  qualification
  proposal
  negotiation
  closed_won
  closed_lost
}

model CalendarEvent {
  id             Int            @id @default(autoincrement())
  title          String
  date           String
  startTime    String     @map("starttime")
  endTime      String     @map("endtime")
  location       String         @default("")
  notes          String         @default("")
  color          String         @default("primary")
  repeat         EventRepeat    @default(none)
  assignmentKind AssignmentKind @default(none)
  assigneeId     String         @default("")
  assigneeName   String         @default("")
  assigneeMeta   String         @default("")
  authorId       String
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([authorId])
  @@index([deletedAt])
  @@index([date])
  @@index([assigneeId])
}

enum MeetingType {
  demo
  discovery
  proposal
  negotiation
  onboarding
  check_in
  other
}

enum MeetingStatus {
  scheduled
  completed
  cancelled
  no_show
}

model Meeting {
  id            Int           @id @default(autoincrement())
  leadId        Int?
  clientId      Int?
  contactId     Int?
  title         String
  type          MeetingType   @default(other)
  scheduledAt   DateTime
  duration      Int           @default(30)
  meetingUrl    String?
  hostId        String
  hostName      String
  inviteeEmail  String
  inviteeName   String
  agenda        String        @default("")
  notes         String?
  status        MeetingStatus @default(scheduled)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lead          Lead?         @relation(fields: [leadId], references: [id])
  client        Client?       @relation(fields: [clientId], references: [id])
  contact       Contact?      @relation(fields: [contactId], references: [id])

  @@index([leadId])
  @@index([clientId])
  @@index([contactId])
  @@index([scheduledAt])
  @@index([status])
}

enum ActivityType {
  email
  call
  meeting
  note
  stage_change
  task
  other
}

model Activity {
  id          Int          @id @default(autoincrement())
  entityType String
  entityId   Int
  type        ActivityType
  title       String
  description String       @default("")
  metadata    String       @default("")
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Payroll {
  id          Int          @id @default(autoincrement())
  memberId    String
  memberName  String
  department  String       @default("")
  period     String
  baseSalary Int
  allowances Int
  deductions Int
  netPay     Int
  status     PayrollStatus @default(pending)
  paymentMode PaymentMode  @default(bank_transfer)
  paidAt     DateTime?
  deletedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([memberId])
  @@index([period])
  @@index([status])
  @@index([deletedAt])
}

enum EventRepeat {
  none
  weekly
  monthly
}

enum AssignmentKind {
  none
  member
  team
}

enum PayrollStatus {
  pending
  processed
  paid
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @default("")
  permissions Json     @default("{}") // Object of service permissions, e.g. {"clients": true, "tasks": false}
  members     TeamMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

// ============================================
// AUTOMATION SYSTEM MODELS
// ============================================

// Trigger types for automation
enum AutomationTrigger {
  lead_created
  lead_updated
  lead_scored
  lead_assigned
  lead_score_above
  lead_score_below
  deal_created
  deal_stage_changed
  deal_closed
  deal_stale
  task_created
  task_completed
  task_overdue
  client_created
  client_health_changed
  client_health_low
  churn_risk
  cold_lead_detected
  followup_due
  renewal_due
  invoice_created
  invoice_overdue
  payroll_due
  project_stalled
  custom_schedule
  manual
}

// Action types that automation can perform
enum AutomationAction {
  send_email
  create_task
  assign_lead
  update_score
  move_deal
  create_client
  send_notification
  tag_entity
  update_field
  webhook
}

// Status of automation rules
enum AutomationRuleStatus {
  active
  paused
  archived
}

// Status of automation logs
enum AutomationLogStatus {
  pending
  running
  completed
  failed
  cancelled
}

// Automation Rules - Define what automation to run
model AutomationRule {
  id          Int                   @id @default(autoincrement())
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json                  @default("[]") // Array of condition objects
  actions     Json                  @default("[]") // Array of action objects
  
  // Scheduling (for custom_schedule trigger)
  cronExpression String?            // e.g., "0 9 * * *" for daily at 9am
  isActive       Boolean            @default(true)
  status        AutomationRuleStatus @default(active)
  
  // Metadata
  priority     Int                  @default(0) // Higher = runs first
  maxRunsPerDay Int?               // Limit daily executions
  
  // Usage tracking
  runCount     Int                  @default(0)
  lastRunAt    DateTime?
  lastRunError String?
  
  // Relations
  logs         AutomationLog[]
  createdBy    String?             // User email who created
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([trigger])
  @@index([status])
  @@index([isActive])
}

// Automation Logs - Track execution history
model AutomationLog {
  id          Int                   @id @default(autoincrement())
  ruleId      Int
  rule        AutomationRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  
  trigger     String                // The trigger that fired
  triggerData Json                 @default("{}") // Original event data
  actionData  Json                 @default("[]") // Actions executed
  
  status      AutomationLogStatus   @default(pending)
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  error       String?
  
  // What was affected
  entityType  String?               // "Lead", "Deal", "Task", etc.
  entityId    Int?
  
  // Execution details
  durationMs  Int?                 // How long it took
  
  createdAt   DateTime             @default(now())

  @@index([ruleId])
  @@index([status])
  @@index([entityType, entityId])
  @@index([startedAt])
}

// Scheduled Jobs - For one-time or recurring scheduled tasks
enum ScheduledJobType {
  email
  task
  alert
  webhook
  reminder
}

enum ScheduledJobStatus {
  pending
  running
  completed
  failed
  cancelled
}

model ScheduledJob {
  id          Int                 @id @default(autoincrement())
  
  jobType     ScheduledJobType
  name        String
  description String?
  
  // Scheduling
  scheduledFor DateTime           // When to run
  cronExpression String?          // For recurring jobs
  
  // Payload - what to execute
  payload     Json               @default("{}")
  
  // Status
  status      ScheduledJobStatus  @default(pending)
  
  // For recurring jobs
  isRecurring Boolean            @default(false)
  nextRunAt   DateTime?
  
  // Execution tracking
  runCount    Int                @default(0)
  lastRunAt   DateTime?
  lastError   String?
  
  // Who/What this is for
  entityType  String?             // "Lead", "Deal", "Client", etc.
  entityId    Int?
  
  // Who created this
  createdBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, scheduledFor])
  @@index([entityType, entityId])
  @@index([isRecurring])
}

// Email Queue - For sending emails with retry logic
enum EmailQueueStatus {
  pending
  sending
  sent
  failed
  cancelled
}

model EmailQueue {
  id          Int               @id @default(autoincrement())
  
  // Email details
  to          String
  cc          String?
  bcc         String?
  subject     String
  body        String            @db.Text
  htmlBody    String?           @db.Text
  
  // Template info
  template    String?          // Template name if using template
  templateData Json?            @default("{}")
  
  // Scheduling
  scheduledFor DateTime?        // Optional delay
  sendAfter    DateTime?        // Send after this time
  
  // Status
  status      EmailQueueStatus  @default(pending)
  
  // Retry logic
  retryCount  Int               @default(0)
  maxRetries  Int               @default(3)
  lastError   String?
  nextRetryAt DateTime?
  
  // Tracking
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  
  // Metadata
  entityType  String?           // What this email is related to
  entityId   Int?
  
  // Who it's for
  recipientName String?
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, scheduledFor])
  @@index([entityType, entityId])
  @@index([to])
}

// Activity Log - Track all CRM activities for automation triggers
model ActivityLog {
  id          Int               @id @default(autoincrement())
  
  // What happened
  action      String            // "created", "updated", "deleted", "viewed", etc.
  entityType  String            // "Lead", "Deal", "Client", etc.
  entityId    Int
  
  // Details
  description String?            // Human readable description
  changes    Json?              @default("{}") // What changed
  metadata   Json?               @default("{}")
  
  // Who did it
  performedBy String?           // User email
  performedByName String?
  
  // For activity feed
  isVisible  Boolean            @default(true)
  icon       String?            // Icon name for UI
  color      String?            // Color for UI
  
  createdAt  DateTime           @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
  @@index([action])
  @@index([isVisible, createdAt])
}

// Alert model for automation alerts
enum AlertType {
  health_warning
  churn_risk
  stale_deal
  escalation
  renewal_reminder
  custom
}

enum AlertSeverity {
  info
  warning
  critical
}

model Alert {
  id          Int          @id @default(autoincrement())
  type        AlertType    @default(custom)
  severity    AlertSeverity @default(warning)
  title       String
  message     String
  entityType  String?      // "Lead", "Deal", "Client", etc.
  entityId    Int?
  
  // Resolution
  isResolved  Boolean      @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  
  // Metadata
  metadata    Json?        @default("{}")
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([entityType, entityId])
  @@index([isResolved])
  @@index([severity])
  @@index([createdAt])
  @@index([type])
}

model CsvImport {
  id           Int       @id @default(autoincrement())
  filename     String
  totalRows    Int       @default(0)
  successCount Int       @default(0)
  errorCount   Int       @default(0)
  status       CsvImportStatus @default(pending)
  errors       String[]  @default([])
  importedBy   String
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([importedBy])
}

enum CsvImportStatus {
  pending
  processing
  completed
  failed
}
