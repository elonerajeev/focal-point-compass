generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id              Int            @id @default(autoincrement())
  name            String
  email           String         @unique
  jobId           Int
  stage           CandidateStage @default(applied)
  resume          String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  source          String?        @default("Direct")
  phone           String?
  rating          Int?           @default(0)
  interviewDate   DateTime?      @db.Timestamp(6)
  interviewers    String[]       @default([])
  offerLetterSent Boolean?       @default(false)
  joiningDate     String?
  offeredSalary   String?
  JobPosting      JobPosting     @relation(fields: [jobId], references: [id])

  @@index([deletedAt])
  @@index([jobId])
  @@index([stage])
  @@index([source])
  @@index([rating])
}

model Client {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  industry    String        @default("General")
  manager     String        @default("Unassigned")
  status      ClientStatus  @default(pending)
  revenue     String        @default("$0")
  location    String        @default("Unknown")
  avatar      String
  tier        ClientTier    @default(Growth)
  healthScore Int           @default(75)
  nextAction  String        @default("Initial contact")
  segment     ClientSegment @default(new_business)
  companyId   String?
  jobTitle    String?
  source      String?
  assignedTo  String?
  phone       String        @default("")
  company     String        @default("")
  tags        String[]      @default([])
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime

  @@index([company])
  @@index([deletedAt])
  @@index([status])
  @@index([tier])
}

model Conversation {
  id          Int       @id @default(autoincrement())
  name        String
  avatar      String
  lastMessage String
  time        String
  unread      Int       @default(0)
  online      Boolean   @default(false)
  team        String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Message     Message[]

  @@index([deletedAt])
  @@index([updatedAt])
}

model Invoice {
  id        String       @id
  client    String
  amount    String
  date      String
  due       String
  status    ClientStatus @default(pending)
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime

  @@index([deletedAt])
  @@index([status])
}

model JobPosting {
  id          Int         @id @default(autoincrement())
  title       String
  department  String
  location    String
  type        String      @default("Full-time")
  status      JobStatus   @default(open)
  description String      @default("")
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  salary      String?     @default("Competitive")
  experience  String?     @default("2-5 years")
  skills      String[]    @default([])
  views       Int?        @default(0)
  deadline    String?
  priority    String?     @default("normal")
  Candidate   Candidate[]

  @@index([deletedAt])
  @@index([status])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  sender         String
  text           String
  time           String
  isMe           Boolean      @default(false)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([deletedAt])
}

model Note {
  id        Int       @id @default(autoincrement())
  title     String
  content   String    @default("")
  isPinned  Boolean   @default(false)
  color     String    @default("default")
  authorId  String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime

  @@index([authorId])
  @@index([deletedAt])
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  description String        @default("")
  progress    Int           @default(0)
  status      ProjectStatus @default(pending)
  team        String[]      @default([])
  dueDate     String        @default("")
  stage       ProjectStage  @default(Discovery)
  budget      String        @default("$0")
  tasksDone   Int           @default(0)
  tasksTotal  Int           @default(0)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  tasks       Task[]

  @@index([deletedAt])
  @@index([stage])
  @@index([status])
}

model RefreshToken {
  id        String    @id
  userId    String
  tokenHash String    @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  assignee    String
  avatar      String
  priority    TaskPriority
  dueDate     String
  tags        String[]     @default([])
  valueStream String
  column      TaskColumn   @default(todo)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  projectId   Int?
  project     Project?     @relation(fields: [projectId], references: [id], onUpdate: NoAction)

  @@index([column])
  @@index([deletedAt])
  @@index([priority])
  @@index([projectId])
}

model TeamMember {
  id                    Int            @id @default(autoincrement())
  name                  String
  email                 String         @unique
  role                  TeamMemberRole
  status                ClientStatus   @default(active)
  avatar                String
  department            String
  team                  String
  teamId                Int?
  teamRef               Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  designation           String
  manager               String
  workingHours          String
  officeLocation        String
  timeZone              String
  baseSalary            Int
  allowances            Int
  deductions            Int
  paymentMode           PaymentMode
  warningCount          Int            @default(0)
  suspendedAt           DateTime?
  terminationEligibleAt DateTime?
  handoverCompletedAt   DateTime?
  terminatedAt          DateTime?
  separationNote        String?
  attendance            String         @default("present")
  checkIn               String         @default("-")
  location              String         @default("-")
  workload              Int            @default(0)
  deletedAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime

  @@index([deletedAt])
  @@index([role])
  @@index([status])
  @@index([teamId])
}

model User {
  id             String         @id
  name           String
  email          String         @unique
  passwordHash   String
  emailVerified  Boolean        @default(false)
  role           UserRole
  employeeId     String         @unique
  department     String
  team           String
  designation    String
  manager        String
  workingHours   String
  officeLocation String
  timeZone       String
  baseSalary     Int
  allowances     Int
  deductions     Int
  paymentMode    PaymentMode
  payrollCycle   String
  payrollDueDate String
  joinedAt       String
  location       String
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  signatureUrl   String?
  RefreshToken   RefreshToken[]
}

model UserPreference {
  id        String   @id
  userId    String   @unique
  data      Json     @default("{}")
  updatedAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Lead {
  id         Int        @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String     @unique
  company    String
  jobTitle   String?
  phone      String?
  status     LeadStatus @default(new)
  source     LeadSource @default(website)
  score      Int        @default(50)
  assignedTo String?
  notes      String?
  tags       String[]   @default([])
  convertedAt DateTime?
  convertedToClientId Int?
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([deletedAt])
  @@index([status])
  @@index([source])
}

model Deal {
  id            Int            @id @default(autoincrement())
  title         String
  value         Int
  currency      String         @default("USD")
  stage         DealStage      @default(prospecting)
  probability   Int            @default(50)
  assignedTo    String?
  expectedClose DateTime?
  actualClose   DateTime?
  description   String?
  tags          String[]       @default([])
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activities    DealActivity[]

  @@index([deletedAt])
  @@index([stage])
}

model DealActivity {
  id        Int      @id @default(autoincrement())
  dealId    Int
  type      String
  content   String
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model CandidateActivity {
  id          Int      @id @default(autoincrement())
  candidateId Int
  action      String
  detail      String
  performedBy String
  createdAt   DateTime @default(now())

  @@index([candidateId])
}

model Integration {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  status    String   @default("active")
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  admin
  manager
  employee
  client
}

enum PaymentMode {
  bank_transfer
  cash
  upi
}

enum ClientStatus {
  active
  pending
  completed
}

enum ClientTier {
  Enterprise
  Growth
  Strategic
}

enum ClientSegment {
  Expansion
  Renewal
  new_business
}

enum ProjectStatus {
  active
  pending
  completed
  in_progress
}

enum ProjectStage {
  Discovery
  Build
  Review
  Launch
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskColumn {
  todo
  in_progress
  done
}

enum TeamMemberRole {
  Admin
  Manager
  Employee
}

enum JobStatus {
  open
  draft
  closed
}

enum CandidateStage {
  applied
  screening
  interview
  offer
  hired
  rejected
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  negotiation
  closed_won
  closed_lost
}

enum LeadSource {
  website
  referral
  social
  email
  other
}

enum DealStage {
  prospecting
  qualification
  proposal
  negotiation
  closed_won
  closed_lost
}

model CalendarEvent {
  id             Int            @id @default(autoincrement())
  title          String
  date           String
  startTime    String     @map("starttime")
  endTime      String     @map("endtime")
  location       String         @default("")
  notes          String         @default("")
  color          String         @default("primary")
  repeat         EventRepeat    @default(none)
  assignmentKind AssignmentKind @default(none)
  assigneeId     String         @default("")
  assigneeName   String         @default("")
  assigneeMeta   String         @default("")
  authorId       String
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([authorId])
  @@index([deletedAt])
  @@index([date])
  @@index([assigneeId])
}

model Payroll {
  id          Int          @id @default(autoincrement())
  memberId    String
  memberName  String
  department  String       @default("")
  period     String
  baseSalary Int
  allowances Int
  deductions Int
  netPay     Int
  status     PayrollStatus @default(pending)
  paymentMode PaymentMode  @default(bank_transfer)
  paidAt     DateTime?
  deletedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([memberId])
  @@index([period])
  @@index([status])
  @@index([deletedAt])
}

enum EventRepeat {
  none
  weekly
  monthly
}

enum AssignmentKind {
  none
  member
  team
}

enum PayrollStatus {
  pending
  processed
  paid
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @default("")
  permissions Json     @default("{}") // Object of service permissions, e.g. {"clients": true, "tasks": false}
  members     TeamMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}
