NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_ACCESS_SECRET=generate_with_node_crypto_randomBytes_64_hex
JWT_REFRESH_SECRET=generate_with_node_crypto_randomBytes_64_hex
